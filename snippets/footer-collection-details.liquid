<!------------snippet/footer-collection-details.liquid-------------->

{% if collection.metafields.custom.footer_description_collection != blank %}
<div class="main_footer_description page-width">
  <div class="description_contain">
    {{ collection.metafields.custom.footer_description_collection | metafield_tag  }}
  </div>
</div>

{% endif %}
{% if template contains 'collection' and collection.metafields.custom.faq_json != blank %}
  <script type="application/ld+json">
   {{ collection.metafields.custom.faq_json  }}
  </script>
{% endif %}

{% if collection.metafields.custom.popular_tags != blank %}
<div class="popular_srch">
  <div class="page-width">
    <h3>Popular Searches:</h3>
    {{ collection.metafields.custom.popular_tags | metafield_tag }}
  </div>
</div>
{% endif %}
<style>
.main_footer_description{
  display: block;
 
  width: 100%;
} 
.metafield-rich_text_field ul li, .metafield-rich_text_field h3, .metafield-rich_text_field h2,.metafield-rich_text_field p{
  font-family: Avenir-Roman;
  font-size: 1.6rem;
}
.main_footer_description .description_contain h2{
  font-size: 1.6rem;
  line-height: 15px ;
  letter-spacing: 0px;
  font-weight: 600;
  margin:10px 0;
}
.main_footer_description .description_contain h3{
  margin-top: 25px;
  margin-bottom:9px;
  line-height: 15px;
  font-size: 1.6rem;
  letter-spacing: 0px;
  font-weight: 600;
}
.main_footer_description .description_contain p,
.popular_srch p{
  font-size: 1.5rem;
  line-height: 20px;
  letter-spacing: .02rem;
  text-transform: capitalize;
}
.main_footer_description .description_contain a,
.popular_srch a{
   color: #000;
   border-bottom: 1px solid #00000026;
   text-decoration: none;
}
.popular_srch h3{
  margin-top: 25px;
  margin-bottom:9px;
  line-height: 15px;
  font-size: 14px;
  letter-spacing: 0px;
  font-weight: 600;
}
</style>