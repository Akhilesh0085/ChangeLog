 {%- assign w3_script_type = '' -%}
    {%- assign w3_css_type = '' -%}
    {%- unless request.design_mode or template contains 'cart' or template contains 'checkout' -%}
        {%- assign w3_script_type = ' type="lazyJs"' -%}
        {%- assign w3_css_type = ' data-' -%}
    {%- endunless -%}


{% if template.name == 'product' %}
  <script {{w3_script_type}} defer>
    (function () {
      function loadScript(src, callback) {
        var s = document.createElement('script');
        s.src = src;
        s.defer = true;
        s.onload = callback || function () {};
        document.head.appendChild(s);
      }

      if (window.innerWidth >= 768) {
        loadScript('{{ "jquery.min.js" | asset_url }}', function () {
          loadScript('{{ "slick.min.js" | asset_url }}', function () {
            loadScript('{{ "custom.min.js" | asset_url }}');
          });
        });
      }
    })();
  </script>

{% else %}
  <script  {{w3_script_type}} src="{{ 'jquery.min.js' | asset_url }}"></script>
  <script {{w3_script_type}} src="{{ 'slick.min.js' | asset_url }}" defer></script>
  <script {{w3_script_type}} src="{{ 'custom.min.js' | asset_url }}" defer></script>
{% endif %}

{% if template.name == 'product' %}
  {% render 'product-render-js-asset' %}
{% endif %}

{% if template.name != 'product' %}
  <script {{w3_script_type}} src="{{ 'vendor-v4.js' | asset_url | split: '?' | first }}" defer></script>
  <script {{w3_script_type}} src="{{ 'pubsub.js' | asset_url }}" defer></script>
  <script {{w3_script_type}} src="{{ 'global.js' | asset_url }}" defer></script>
{% else %}
  {% render 'lazy-js', filename: 'vendor-v4.js', loading: 'lazy' %}
  {% render 'lazy-js', filename: 'pubsub.js', loading: 'lazy' %}
  {% render 'lazy-js', filename: 'global.js', loading: 'lazy' %}
{% endif %}
