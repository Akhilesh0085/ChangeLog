{%- assign text_direction = 'localization.text_direction_trigger' | t | downcase -%}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" {%- if text_direction == 'rtl' %} dir="rtl" {% endif -%}>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <meta name="google-site-verification" content="7VAw5_qKHiqi3G0cz3cTKqqcTJya2qfuJeNUtc9FbhQ">
    {%- if request.path contains '/404' -%}
      <meta http-equiv="refresh" content="0; url=https://shopforaurelia.com/">
    {%- endif -%}
    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}
    {% render 'meta-tags' %}
    {% render 'canonical_url' %}
    {% render 'favicon' %}
    {% render 'dns-prefetches' %}
    {% if request.path contains '/products/' %}
      <title>
        Buy
        {{ product.title }}
        Online for Woman | Shop for Aurelia
      </title>
      <meta
        name="description"
        content="Shop {{ product.title }} online for woman from our best collections at Aurelia for all occasions. Check out our prices, offers, colors, fabrics, size charts."
      >
    {% else %}
      <title>
        {{ page_title }}
        {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
        {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
      </title>
    {% endif %}

    {% if template.name == 'index' %}
      <link
        fetchpriority="high"
        rel="preload"
        href="https://shopforaurelia.com/cdn/shop/files/Valentine_s_Day-mob-Banner_copy_588f7b5a-7d58-40b2-b461-4ca877b828e9.jpg?v=1770958747&width=1100"
        as="image"
      >
    {% endif %}

    {% if template contains 'product' %}
      <link rel="preload" fetchpriority="high" as="image" oott href="{{ product.media[0] | image_url:width:596}}">
    {% endif %}

    {% assign firstProduct = collection.products.first %}
    {% if template.name == 'collection' %}
      {% if collection.featured_image %}
        {% assign plp_banner = collection.featured_image %}
        <link rel="preload" fetchpriority="high" href="{{ plp_banner | img_url:'master' }}" as="image">
      {% else %}
        {% if firstProduct and firstProduct.available %}
          <link
            rel="preload"
            fetchpriority="high"
            href="{{ firstProduct.featured_image | image_url: width: '388' }}"
            as="image"
          >
        {% endif %}
      {% endif %}
    {% endif %}

    {{ 'slick.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'slick-theme.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'wishlist-notify.css' | asset_url | stylesheet_tag: preload: true }}

    {% comment %} {% render 'image-preloads' %} {% endcomment %}
    {% render 'font-preloads' %}
    {% render 'shopforaureliain' %}

    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

    {% render 'robots_tag' %}

    {% comment %} Critical assets {% endcomment %}
    {% render 'core-assets' %}

    {% render 'theme-css' %}
    <script src="{{ 'jquery.min.js' | asset_url }}" defer></script>

    {% render 'theme-scripts' %}

    {% comment %} Shopify Content {% endcomment %}
    {{ content_for_header }}

    {% comment %} CSS Variables & JS Variables {% endcomment %}
    {% render 'css-variables' %}
    {%- render 'js-variables' -%}
    {% render 'aurelia-india-section' %}

    {% comment %} Internal Styles {% endcomment %}
    {% render 'internal-styles' %}

    {% comment %} Redirect {% endcomment %}
    {% render 'redirects' %}

    {% comment %} Third-party Script {% endcomment %}
    {% render 'sr-checkout' %}

    {% comment %} Admitad Tracking {% endcomment %}
    {% comment %} {% render 'admitad-tracking' %} {% endcomment %}

    <script type="text/javascript" src="{{ 'slick.min.js' | asset_url }}" defer></script>
    <script src="{{ 'custom.min.js' | asset_url }}" defer></script>
    <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'wishlist-notify.js' | asset_url }}" defer="defer"></script>
  </head>

  <body
    class="template-{{ request.page_type }}{% if request.design_mode %} shopify-design-mode{% endif %}"
    {%- if settings.image_zoom_effect_enabled %}
      data-animate-image
    {% endif -%}
    {%- if settings.image_loading_bar_enabled %}
      data-lazy-image
    {% endif -%}
    {%- if settings.heading_capitalize %}
      data-heading-capitalize
    {% endif -%}
    {%- if settings.heading_center %}
      data-heading-center
    {% endif -%}
    {%- if settings.price_superscript %}
      data-price-superscript
    {% endif -%}
    {%- if settings.button_corner_radius > 0 %}
      data-button-round
    {% endif -%}
  >
    {% comment %} Accessibility Skip Link {% endcomment %}
    {% render 'accessibility-skip-link' %}

    <noscript defer>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-M7WLTK8"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <!-- --login Popup---- -->
    <div id="loginPopup">
      <div class="noti_pop_log">
        <span class="popup-close">✖</span>
        <h3>Please Login</h3>
        <p>This feature requires you to log in first</p>
        <a href="/account/login?return_to={{ request.path }}" class="button">Login</a>
      </div>
    </div>

    <!-- Notify Me Popup -->
    <div id="notifyMePopup" class="notify-popup" style="display:none;">
      <div class="notify-content">
        <span class="close-popup">&times;</span>
        <h3>Size You Need:</h3>
        {% comment %} <p>Size You Need:</p> {% endcomment %}
        <div id="outOfStockVariants"></div>
        <button id="notifySubmit">Submit</button>
      </div>
    </div>

    <!-- Notify Popup -->
    <div id="notifyPopup" class="success_popup">
      <p>Product added to notify list</p>
    </div>

    <!-- Wishlist Popup -->
    <div id="wishlistPopup" class="success_popup">
      <p>Added to your wishlist.</p>
    </div>

    {% render 'transition-cover' %}

    <div class="transition-body">
      {% sections 'header-group' %}

      <div class="transition-content">
        <main id="MainContent" class="content-for-layout focus-none shopify-section" role="main" tabindex="-1">
          {{ content_for_layout }}
        </main>

        {% sections 'footer-group' %}
      </div>
    </div>

    {% sections 'overlay-group' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>

    {% render 'icon-cart' %}

    {% section 'scrollup' %}
    {% render 'otp-login' %}
    {% render 'new-font' %}
    {% render 'cartpage-coupon-popup' %}

    {% if template contains 'collection' %}
      {% render 'similar-pop-up' %}
    {% endif %}
    {% render 'mobile-size-card-product' %}

    {% comment %} Custom Scripts {% endcomment %}
    {% render 'custom-scripts' %}

    {% comment %} Custom CSS {% endcomment %}
    {% render 'custom-css' %}

    {% render 'third-party-tracking' %}

    {% render 'wizzy.search.filters.scripts' %}
    {% render 'wizzy.search.filters.styles' %}
    {%- render 'user-logger' -%}
    <script defer="true" src="https://connect.facebook.net/en_US/fbevents.js"></script>
    <script defer>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
        };
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = !0;
        n.version = '2.0';
        n.queue = [];
        t = b.createElement(e);
        t.async = !0;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');

      fbq('init', '777144885825576');
      fbq('track', 'PageView');
    </script>
  </body>
</html>
