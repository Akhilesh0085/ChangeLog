<!---------/sections/tab-collection-load-more.liquid------------>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-position: {{ section.settings.image_position }};
  }
{%- endstyle -%}

<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.quick_view_enabled and section.settings.enable_quick_view -%}
  <link rel="stylesheet" href="{{ 'section-main-product.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'component-product-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'tab-collection.css' | asset_url | stylesheet_tag }}

<div class="section--padding{% if section.settings.show_divider %} section--divider{% endif %} custom_tabsbar_index">
  <div class="page-width page-width--inner">
    <div class="cstm___nav__tab">
     <div class="cstm_tab_def section-header">
       {% for block in section.blocks %}
        <div class="title-wrapper{% if block.settings.heading == blank %} title-wrapper--no-heading{% endif %} {{ block.settings.heading_alignment }}">
          <div class="tab__heading {% if forloop.first %}current_tab{% endif %}" tab-index="{{ block.settings.heading | handleize }}">  
           <{{ block.settings.heading_tag }} class="title {{ block.settings.heading_size }} {% if template contains 'index' %} breadleysans {% endif %}">{{ block.settings.heading | escape }}</{{ block.settings.heading_tag }}>
          </div>
         </div>
       {% endfor %}
    </div>
   </div>

  {% for block in section.blocks %}
    <div class="cstm_tab_content cstm__{{ block.settings.heading | handleize }} {% if forloop.first %} active_content{% endif %} {% unless forloop.first %} hide_tab_content{% endunless %}">          
    {%- liquid
      assign products_to_display = block.settings.collection.all_products_count

      if block.settings.collection.all_products_count > block.settings.products_to_show
        assign products_to_display = block.settings.products_to_show
      endif

      assign class_slider = 'slider--tablet'
      assign class_grid_2_col_tablet = 'grid--2-col-tablet'
      assign class_grid_3_col_tablet = 'grid--3-col-tablet'
      assign class_grid_3_col_desktop = 'grid--3-col-desktop'
      assign class_grid_4_col_desktop = 'grid--4-col-desktop'
      if block.settings.horizontal_scroll
        assign class_grid_2_col_tablet = 'grid--2p3-col-tablet'
        assign class_grid_3_col_tablet = 'grid--3p3-col-tablet'
        assign class_grid_3_col_desktop = 'grid--3p3-col-desktop'
        assign class_grid_4_col_desktop = 'grid--4p3-col-desktop'
        assign class_slider = class_slider | append: ' slider--tablet-up'
      endif
    %}

    {% if block.settings.enable_slider == false %}
      <slider-component class="slider-mobile-gutter">
    {% else %}
      <div class="cstm_slider">
    {% endif %}
 <ul id="product-grid-{{ block.id }}"
  class="product-grid grid grid--rigid {% if block.settings.enable_slider == true %}cstm_product_slider {% endif %} {% if block.settings.columns_mobile == '1' %} grid--1-col-mobile{% endif %} grid--2-col-tablet grid--4-col-desktop {% if block.settings.collection.all_products_count > 2 and block.settings.swipe_on_mobile and block.settings.products_to_show > 2 %} slider {{ class_slider }}{% endif %}{% if block.settings.collection == blank and block.settings.swipe_on_mobile %} slider {{ class_slider }}{% endif %}"
  role="list"
  id="product-grid-{{ block.id }}"
  class="product-grid grid grid--rigid grid--4-col-desktop grid--2-col-tablet"
  data-collection-handle="{{ block.settings.collection.handle }}"
>
  {% for product in block.settings.collection.products %}
    {% if product.available %}
      <li class="grid__item cstm-product-item{% if block.settings.swipe_on_mobile %} slider__slide{% endif %}">
        {% render 'card-product',
          card_product: product,
          card_collection: block.settings.collection,
          media_size: block.settings.image_ratio,
          show_secondary_image: block.settings.show_secondary_image,
          show_quick_buy: block.settings.show_quick_buy,
          show_vendor: block.settings.show_vendor,
          show_rating: block.settings.show_rating,
          enable_quick_view: block.settings.enable_quick_view,
          enable_color_swatches: block.settings.enable_color_swatches,
          enable_countdown: block.settings.enable_countdown,
          enable_image_fill: block.settings.enable_image_fill
        %}
      </li>
    {% endif %}
  {%- else -%}
    {%- for i in (1..4) -%}
      <li class="grid__item{% if block.settings.swipe_on_mobile %} slider__slide{% endif %}">
        {% render 'card-product-placeholder', media_size: block.settings.image_ratio %}
      </li>
    {%- endfor -%}
  {%- endfor -%}
</ul>
    {% if block.settings.enable_slider == false %}
      </slider-component>
    {% else %}
        </div>
    {% endif %}

    {% comment %} {%- if block.settings.show_view_all and block.settings.collection.all_products_count > block.settings.products_to_show -%}
      <div class="view-all cstm_tab_view_all_btn center">
        <a href="{{ block.settings.collection.url }}"
          class="button"
          aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: block.settings.collection.title }}"
        >
           <span class="view_all_btn_text">{{ 'sections.featured_collection.view_all' | t }}  &rarr;</span>
        </a>
      </div>
    {%- endif -%} {% endcomment %}

   {%- comment -%} Show More Button {%- endcomment -%}
{% if block.settings.enable_slider == false %}
  <button class="load-more-btn" data-block-id="{{ block.id }}">
    SHOW MORE
  </button>
{% endif %}

  </div>
  {% endfor %}
  </div>
</div>

