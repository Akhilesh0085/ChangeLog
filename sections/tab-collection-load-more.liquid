<style>
.custom_tabsbar_index .cstm___nav__tab .cstm_tab_def.section-header{
  justify-content: center;
  gap: 15px;
}
.custom_tabsbar_index .cstm_tab_content {
  text-align: center;
}
.hidden-item {
  display: none !important;
}
.custom_tabsbar_index .cstm___nav__tab .cstm_tab_def.section-header{
padding-top: 8px;
}
.custom_tabsbar_index .cstm___nav__tab .tab__heading.current_tab .title.h2{
color: #ffac31;
}
.custom_tabsbar_index .cstm___nav__tab .tab__heading{
  border: 1px solid #000;
  background-color: #fff;
  box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 12px;
}
.custom_tabsbar_index .cstm___nav__tab .tab__heading.current_tab{
background-color: #fff;
border: 1px solid #ffac31;
color: #ffac31;
box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 12px;
}
.load-more-btn{
color: #000;
border: 1.5px solid #80808073;
background-color: #fff;
padding: 5px 10px;
margin-top: 15px;
}
.custom_tabsbar_index .title-wrapper .title{
    margin: 0;
}

.cstm_tab_content.hide_tab_content{
display: none;
}
@media (max-width: 1000px) {
.custom_tabsbar_index .grid__item.cstm-product-item{
  width: 32%;
}
}

@media (max-width: 768px) {
.custom_tabsbar_index .grid__item.cstm-product-item{
  width: 49%;
}
.cstm___nav__tab .tab__heading{
    white-space: nowrap;
}
.cstm___nav__tab .cstm_tab_def.section-header{
    overflow: scroll;
    padding-bottom: 8px;
}
}

</style>

<script>
  $(".tab__heading").click(function(){
    const $section = $(this).closest(".page-width--inner");

    $section.find(".cstm_tab_content").removeClass("active_content");
    $section.find(".tab__heading").removeClass("current_tab");

    $(this).addClass("current_tab");

    var tab = $(this).attr('tab-index'); 
    var tab_class = '.cstm__' + tab;
    {% comment %} console.log('Activating tab content:', tab_class); {% endcomment %}

    $section.find(tab_class).addClass("active_content");
  });

  $(".tab__heading").click(function(){
    const $section = $(this).closest(".page-width--inner");

      $section.find(".cstm_tab_content").addClass("hide_tab_content");
         var tab = $(this).attr('tab-index'); 
         var tab_class = '.cstm__' + tab;

         $section.find(tab_class).removeClass("hide_tab_content");

    });
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  document.querySelectorAll(".load-more-btn").forEach(function (button) {
    const blockId = button.dataset.blockId;
    const grid = document.querySelector("#product-grid-" + blockId);

    if (!grid) return;

    if (grid.classList.contains("slick-initialized")) {
      button.style.display = "none";
      return;
    }

    const items = Array.from(grid.children);

    const DEFAULT_SHOW = 6;   // first time
    const PER_CLICK = 15;     // on every click

    let current = DEFAULT_SHOW;

    // 👉 Default: sirf 6 products show
    items.forEach((item, index) => {
      if (index >= DEFAULT_SHOW) {
        item.classList.add("hidden-item");
      }
    });

    button.addEventListener("click", function () {
      let shown = 0;

      for (let i = current; i < items.length; i++) {
        if (shown < PER_CLICK) {
          items[i].classList.remove("hidden-item");
          shown++;
        }
      }

      current += PER_CLICK;

      // 👉 sab products dikh gaye to button hide
      if (current >= items.length) {
        button.style.display = "none";
      }
    });
  });

});
</script>
