  const $element = $('.exchangeable_items');
  $element.on('scroll', function () {
    const scrollLeft = $element.scrollLeft();
    const scrollWidth = $element[0].scrollWidth;
    const clientWidth = $element[0].clientWidth;
    const scrollPercentage = (scrollLeft / (scrollWidth - clientWidth)) * 100;
    if (scrollPercentage >= 95) {
      $('.exchage_load_more').css('visibility', 'visible');
    } else {
      $('.exchage_load_more').css('visibility', 'hidden');
    }
  });

  function products(price, after = null, before = null) {
    fetch(`${urlr}/exchange/products`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        price: price,
        after: after,
        before: before,
      }),
    })
      .then((response) => {
        return response.json();
      })
      .then((response) => {
        if (response.success === true) {
          const container = $('.exchangeable_items');
          response?.products?.products?.nodes?.forEach((product) => {
            const grid = `<div class="exhange_item">
            <div class="">
              <div class="image">
                <img class="exchange_item_image" src="${product?.featuredMedia?.preview?.image?.url}" alt="${
              product?.featuredMedia?.alt
            }" title="${product?.featuredMedia?.alt}" width="295" height="400" />
              </div>
              <div class="description">
                <div class="product-title"><span class="h4 font-bold-heading product_title">${
                  product?.title
                }</span></div>
                <div class="product-price"><span class="exhange_item_price">${window.theme.Currency.formatMoney(
                  product?.variants?.nodes[0]?.price,
                  window.theme.shopSettings.moneyFormat
                )}</span></div>
                <div class="product-variants">${product?.variants?.nodes
                  ?.map((variant) => {
                    return `<div class="variant_line" data-title="${product?.title}-${
                      variant?.title
                    }" data-variant-id="${variant.id.split('/ProductVariant/')[1]}">${variant?.title}</div>`;
                  })
                  .join('')}</div>
              </div>
            </div>
          </div>`;
            container.append(grid);
          });
          const hasNextPage = response?.products?.products?.pageInfo?.hasNextPage,
            nextPageToken = response?.products?.products?.pageInfo?.startCursor;
          if (hasNextPage === true) {
            $('.exchange__card_button').removeAttr('disabled');
            $('.exchange__card_button').attr('after', nextPageToken);
          } else {
            $('.exchange__card_button').attr('disabled', 'disabled');
          }
        }
        $('.exchange_loader').hide();
        $('.exchangeable_items').show();
      })
      .catch((error) => {
        console.error('Error in getting products: ', error.message);
      });
  }

