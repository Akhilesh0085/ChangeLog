  $('.initiate_exchange_button').on('click', function (e) {
    const reason = $(this).attr('reason'),
      newVariant = $(this).attr('new-variant-id'),
      originalOrderId = $(this).attr('original-order-id'),
      variantId = $(this).attr('variant-id'),
      lineId = $(this).attr('original-line-id'),
      image = $(this).parents('.exchange_line').find('.refund_image_uploader');
    // if (image.val() === "") {
    //   $(".imageError").show();
    //   return false;
    // } else
    if (reason === undefined) {
      $('.reasonError').show();
      return false;
    } else if (newVariant === undefined) {
      $('.productError').show();
      return false;
    } else {
      $('.reasonError .productError .imageError').hide();
      $('body').css('pointer-events', 'none');
      $(this).addClass('loading');
      const formData = {
        orderid: originalOrderId,
        variantid: variantId,
        lineid: lineId,
        newitem: newVariant,
        reason: reason,
        image: '',
      };
      fetch(`${urlr}/exchange/create-exchange`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(formData),
      })
        .then((response) => {
          return response.json();
        })
        .then((response) => {
          if (response.success) {
            $('.main_exchange_popup').hide();
            $('.return.exchange_overlay').show();
          } else {
            $('body').css('pointer-events', '');
            $(this).removeClass('loading');
          }
        })
        .catch((error) => {
          console.log('Error in exchanging order: ', error.message);
          window.location.reload();
        })
        .finally(() => {});
    }
  });
</script>
